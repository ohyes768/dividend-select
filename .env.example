# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 推荐：实际部署用 .env.local（已在 .gitignore），优先级最高

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# API Gateway 配置（可选）
# API_GATEWAY_URL=http://localhost:8010

# 阿里云行情 API（K线数据，APPCODE 鉴权）
# 用于 DividendCalculator._get_price_from_aliyun()
# ALIYUN_API_HOST=http://alirmcom2.market.alicloudapi.com
# ALIYUN_API_PATH=/query/comkm
# ALIYUN_API_APPCODE=your_appcode_here